# Application Settings
APP_NAME="AI Anticancer Drug System"
APP_VERSION="2.0.0"
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/anticancer_db
# For development with SQLite, use:
# DATABASE_URL=sqlite:///./anticancer.db

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload
UPLOAD_FOLDER=uploads/
MAX_FILE_SIZE=16777216  # 16MB
ALLOWED_EXTENSIONS=.png,.jpg,.jpeg,.tif,.tiff,.xlsx,.csv

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# AI Models
MODEL_PATH=../models/
CELLPOSE_MODEL=cyto2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
